# Copy to .env and fill in. Real .env is gitignored.

# Local Postgres (matches docker-compose).
DATABASE_URL=postgresql+psycopg://palisade:palisade@localhost:5432/palisade

# External advisory sources (optional until ingestion/scan PRs).
NVD_API_KEY=
GITHUB_TOKEN=

# LLM provider (optional until agent PRs).
ANTHROPIC_API_KEY=
STRONG_MODEL=claude-opus-4-8
CHEAP_MODEL=claude-haiku-4-5-20251001

# Observability (optional).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
